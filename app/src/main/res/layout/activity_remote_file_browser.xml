<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorOnPrimary"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/colorSecondary"
        android:theme="@style/Widget.MaterialComponents.Toolbar.Primary"
        app:title="Удалённый браузер" />

    <TextView
        android:id="@+id/path_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:text="Подготовка..."
        android:textColor="?attr/colorOnSecondary"
        android:textSize="14sp"
        android:singleLine="true"
        android:ellipsize="middle"
        tools:text="/storage/emulated/0" />

    <TextView
        android:id="@+id/session_status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:text="Ожидание инициализации..."
        android:textColor="?attr/colorOnSecondary"
        android:textSize="12sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/file_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="6dp"
        tools:listitem="@layout/item_remote_file_browser" />

    <TextView
        android:id="@+id/empty_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="24dp"
        android:text="Нет данных"
        android:visibility="gone"
        android:textColor="?attr/colorSecondary" />
</LinearLayout>
