<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SingBoxClient.Desktop.ViewModels"
             xmlns:local="using:SingBoxClient.Desktop"
             x:Class="SingBoxClient.Desktop.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             mc:Ignorable="d"
             d:DesignWidth="880" d:DesignHeight="640">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <DockPanel Margin="24,20" LastChildFill="True">

            <!-- ═══════════════════════════════════════════════════════
                 Header
                 ═══════════════════════════════════════════════════════ -->
            <TextBlock DockPanel.Dock="Top"
                       Text="{Binding [Settings], Source={x:Static local:LocalizationManager.Instance}}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,0,16" />

            <!-- ═══════════════════════════════════════════════════════
                 Bottom Action Buttons
                 ═══════════════════════════════════════════════════════ -->
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="10"
                        Margin="0,20,0,0">
                <Button Content="{Binding [Cancel], Source={x:Static local:LocalizationManager.Instance}}"
                        Background="{DynamicResource BgInputBrush}"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        CornerRadius="8"
                        Padding="20,8"
                        FontSize="13"
                        Command="{Binding CancelCommand}" />
                <Button Content="{Binding [Save], Source={x:Static local:LocalizationManager.Instance}}"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        CornerRadius="8"
                        Padding="20,8"
                        FontSize="13"
                        Command="{Binding SaveCommand}" />
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════════
                 Settings Sections
                 ═══════════════════════════════════════════════════════ -->
            <StackPanel Spacing="16">

                <!-- ── Section 1: Proxy Port ────────────────────────── -->
                <Border Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="18,14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding [ProxyConfiguration], Source={x:Static local:LocalizationManager.Instance}}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold" />

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding [LocalProxyPort], Source={x:Static local:LocalizationManager.Instance}}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Width="160" />
                            <NumericUpDown Grid.Column="1"
                                           Value="{Binding ProxyPort}"
                                           Minimum="1024"
                                           Maximum="65535"
                                           Increment="1"
                                           FormatString="0"
                                           Background="{DynamicResource BgInputBrush}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           BorderBrush="{DynamicResource BorderBrush}"
                                           CornerRadius="8"
                                           Padding="10,6"
                                           FontSize="13"
                                           HorizontalAlignment="Left"
                                           MinWidth="140" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Section 2: General Settings ──────────────────── -->
                <Border Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="18,14">
                    <StackPanel Spacing="14">
                        <TextBlock Text="{Binding [General], Source={x:Static local:LocalizationManager.Instance}}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold" />

                        <!-- Language -->
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding [Language], Source={x:Static local:LocalizationManager.Instance}}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Width="160" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Languages}"
                                      SelectedItem="{Binding Language}"
                                      Background="{DynamicResource BgInputBrush}"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}"
                                      CornerRadius="8"
                                      Padding="10,6"
                                      FontSize="13"
                                      HorizontalAlignment="Left"
                                      MinWidth="160" />
                        </Grid>

                        <!-- Minimize to tray -->
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding [MinimizeToTray], Source={x:Static local:LocalizationManager.Instance}}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Width="160" />
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding MinimizeToTray}"
                                          OnContent=""
                                          OffContent=""
                                          VerticalAlignment="Center" />
                        </Grid>

                        <!-- Start with Windows -->
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding [StartWithWindows], Source={x:Static local:LocalizationManager.Instance}}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Width="160" />
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding AutoStart}"
                                          OnContent=""
                                          OffContent=""
                                          VerticalAlignment="Center" />
                        </Grid>

                        <!-- Auto-connect -->
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding [AutoConnect], Source={x:Static local:LocalizationManager.Instance}}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Width="160" />
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding AutoConnect}"
                                          OnContent=""
                                          OffContent=""
                                          VerticalAlignment="Center" />
                        </Grid>

                        <!-- Debug mode -->
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding [DebugMode], Source={x:Static local:LocalizationManager.Instance}}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Width="160" />
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding DebugMode}"
                                          OnContent=""
                                          OffContent=""
                                          VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Section 3: Subscription ──────────────────────── -->
                <Border Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="18,14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding [Subscription], Source={x:Static local:LocalizationManager.Instance}}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold" />

                        <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                            <TextBox Grid.Column="0"
                                     Text="{Binding SubscriptionUrl}"
                                     IsReadOnly="True"
                                     Background="{DynamicResource BgInputBrush}"
                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     CornerRadius="8"
                                     Padding="12,8"
                                     FontSize="12"
                                     Watermark="{Binding [NoSubscriptionUrl], Source={x:Static local:LocalizationManager.Instance}}" />
                            <Button Grid.Column="1"
                                    Content="{Binding [Copy], Source={x:Static local:LocalizationManager.Instance}}"
                                    Background="{DynamicResource AccentBrush}"
                                    Foreground="White"
                                    CornerRadius="8"
                                    Padding="14,8"
                                    FontSize="12"
                                    Margin="8,0,0,0"
                                    Command="{Binding CopySubscriptionUrlCommand}" />
                        </Grid>

                        <TextBlock Text="{Binding [SubscriptionUrlNote], Source={x:Static local:LocalizationManager.Instance}}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </DockPanel>
    </ScrollViewer>

</UserControl>
