<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:SingBoxClient.Desktop.ViewModels"
        xmlns:views="using:SingBoxClient.Desktop.Views"
        xmlns:conv="using:SingBoxClient.Desktop.Converters"
        x:Class="SingBoxClient.Desktop.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        mc:Ignorable="d"
        d:DesignWidth="960" d:DesignHeight="640"
        Title="NanoredVPN v1.0.0"
        Width="960" Height="740"
        MinWidth="800" MinHeight="550"
        Background="{DynamicResource BgMainBrush}"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="40">

    <Window.Resources>
        <conv:StringEqualsConverter x:Key="IsActivePage" />
        <conv:ActivePageBrushConverter x:Key="NavIconBrush"
            ActiveBrushKey="AccentLightBrush" InactiveBrushKey="TextSecondaryBrush" />
        <conv:ActivePageBrushConverter x:Key="NavLabelBrush"
            ActiveBrushKey="AccentLightBrush" InactiveBrushKey="TextMutedBrush" />
    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════════════
         Main Layout: Title Bar + (Sidebar | Content)
         ═══════════════════════════════════════════════════════════════════ -->
    <DockPanel LastChildFill="True">

        <!-- ── Title Bar (draggable) ───────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                x:Name="TitleBar"
                Background="{DynamicResource BgSidebarBrush}"
                Height="40"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="12,0">
                <!-- App title -->
                <TextBlock DockPanel.Dock="Left"
                           Text="NanoredVPN v1.0.0"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />

                <!-- Window control buttons -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center">
                    <!-- Theme toggle -->
                    <Button Background="{DynamicResource BgInputBrush}"
                            BorderBrush="{DynamicResource BorderLightBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10,5"
                            ToolTip.Tip="{DynamicResource ToggleTheme}"
                            Command="{Binding ToggleThemeCommand}">
                        <Panel>
                            <!-- Sun icon (dark theme active → switch to light) -->
                            <Path Data="M20 8.69V4h-4.69L12 .69 8.69 4H4v4.69L.69 12 4 15.31V20h4.69L12 23.31 15.31 20H20v-4.69L23.31 12 20 8.69zM12 18c-3.31 0-6-2.69-6-6s2.69-6 6-6 6 2.69 6 6-2.69 6-6 6z"
                                  Fill="{DynamicResource YellowBrush}"
                                  IsVisible="{Binding IsDarkTheme}"
                                  Width="16" Height="16"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center" />
                            <!-- Moon icon (light theme active → switch to dark) -->
                            <Path Data="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
                                  Fill="{DynamicResource AccentLightBrush}"
                                  IsVisible="{Binding !IsDarkTheme}"
                                  Width="16" Height="16"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center" />
                        </Panel>
                    </Button>

                    <!-- Minimize -->
                    <Button Classes="titlebar-btn"
                            ToolTip.Tip="{DynamicResource Minimize}"
                            Command="{Binding MinimizeCommand}">
                        <TextBlock Text="&#x2500;"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="13" />
                    </Button>

                    <!-- Maximize -->
                    <Button Classes="titlebar-btn"
                            ToolTip.Tip="{DynamicResource Maximize}"
                            Command="{Binding MaximizeCommand}">
                        <TextBlock Text="&#x25A1;"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="13" />
                    </Button>

                    <!-- Close -->
                    <Button Classes="titlebar-btn close-btn"
                            ToolTip.Tip="{DynamicResource Close}"
                            Command="{Binding CloseCommand}">
                        <TextBlock Text="&#x2715;"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="13" />
                    </Button>
                </StackPanel>

                <!-- Spacer -->
                <Panel />
            </DockPanel>
        </Border>

        <!-- ── Body: Sidebar + Content ──────────────────────────────── -->
        <Grid ColumnDefinitions="64,*">

            <!-- ── Sidebar ──────────────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BgSidebarBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <StackPanel VerticalAlignment="Top"
                            HorizontalAlignment="Center"
                            Spacing="4"
                            Margin="0,12">

                    <!-- Home -->
                    <Button Classes="nav-button"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Home"
                            ToolTip.Tip="{DynamicResource Home}"
                            IsEnabled="{Binding IsNotNavigating}">
                        <Grid>
                            <!-- Active indicator bar (left edge) -->
                            <Border Width="3" Height="28"
                                    CornerRadius="0,2,2,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="-8,0,0,0"
                                    Background="{DynamicResource AccentBrush}"
                                    IsVisible="{Binding CurrentPageName, Converter={StaticResource IsActivePage}, ConverterParameter=Home}" />
                            <StackPanel HorizontalAlignment="Center" Spacing="2">
                                <TextBlock Text="&#x2302;"
                                           FontSize="20"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding CurrentPageName, Converter={StaticResource NavIconBrush}, ConverterParameter=Home}" />
                                <TextBlock Text="{DynamicResource Home}"
                                           FontSize="9"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding CurrentPageName, Converter={StaticResource NavLabelBrush}, ConverterParameter=Home}" />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- Route -->
                    <Button Classes="nav-button"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Routing"
                            ToolTip.Tip="{DynamicResource Routing}"
                            IsEnabled="{Binding IsNotNavigating}">
                        <Grid>
                            <Border Width="3" Height="28"
                                    CornerRadius="0,2,2,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="-8,0,0,0"
                                    Background="{DynamicResource AccentBrush}"
                                    IsVisible="{Binding CurrentPageName, Converter={StaticResource IsActivePage}, ConverterParameter=Routing}" />
                            <StackPanel HorizontalAlignment="Center" Spacing="2">
                                <TextBlock Text="&#x21C4;"
                                           FontSize="20"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding CurrentPageName, Converter={StaticResource NavIconBrush}, ConverterParameter=Routing}" />
                                <TextBlock Text="{DynamicResource Route}"
                                           FontSize="9"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding CurrentPageName, Converter={StaticResource NavLabelBrush}, ConverterParameter=Routing}" />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- TUN -->
                    <Button Classes="nav-button"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="TunSettings"
                            ToolTip.Tip="{DynamicResource TunSettings}"
                            IsEnabled="{Binding IsNotNavigating}">
                        <Grid>
                            <Border Width="3" Height="28"
                                    CornerRadius="0,2,2,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="-8,0,0,0"
                                    Background="{DynamicResource AccentBrush}"
                                    IsVisible="{Binding CurrentPageName, Converter={StaticResource IsActivePage}, ConverterParameter=TunSettings}" />
                            <StackPanel HorizontalAlignment="Center" Spacing="2">
                                <TextBlock Text="&#x26A1;"
                                           FontSize="20"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding CurrentPageName, Converter={StaticResource NavIconBrush}, ConverterParameter=TunSettings}" />
                                <TextBlock Text="{DynamicResource TUN}"
                                           FontSize="9"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding CurrentPageName, Converter={StaticResource NavLabelBrush}, ConverterParameter=TunSettings}" />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- Logs -->
                    <Button Classes="nav-button"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Logs"
                            ToolTip.Tip="{DynamicResource Logs}"
                            IsEnabled="{Binding IsNotNavigating}">
                        <Grid>
                            <Border Width="3" Height="28"
                                    CornerRadius="0,2,2,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="-8,0,0,0"
                                    Background="{DynamicResource AccentBrush}"
                                    IsVisible="{Binding CurrentPageName, Converter={StaticResource IsActivePage}, ConverterParameter=Logs}" />
                            <StackPanel HorizontalAlignment="Center" Spacing="2">
                                <TextBlock Text="&#x2263;"
                                           FontSize="20"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding CurrentPageName, Converter={StaticResource NavIconBrush}, ConverterParameter=Logs}" />
                                <TextBlock Text="{DynamicResource Logs}"
                                           FontSize="9"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding CurrentPageName, Converter={StaticResource NavLabelBrush}, ConverterParameter=Logs}" />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- Settings -->
                    <Button Classes="nav-button"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Settings"
                            ToolTip.Tip="{DynamicResource Settings}"
                            IsEnabled="{Binding IsNotNavigating}">
                        <Grid>
                            <Border Width="3" Height="28"
                                    CornerRadius="0,2,2,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="-8,0,0,0"
                                    Background="{DynamicResource AccentBrush}"
                                    IsVisible="{Binding CurrentPageName, Converter={StaticResource IsActivePage}, ConverterParameter=Settings}" />
                            <StackPanel HorizontalAlignment="Center" Spacing="2">
                                <TextBlock Text="&#x2699;"
                                           FontSize="20"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding CurrentPageName, Converter={StaticResource NavIconBrush}, ConverterParameter=Settings}" />
                                <TextBlock Text="{DynamicResource Setup}"
                                           FontSize="9"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding CurrentPageName, Converter={StaticResource NavLabelBrush}, ConverterParameter=Settings}" />
                            </StackPanel>
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ── Content Area ─────────────────────────────────────── -->
            <Border Grid.Column="1"
                    Background="{DynamicResource BgContentBrush}">
                <ContentControl Content="{Binding CurrentPage}">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
                            <views:HomeView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:RoutingViewModel}">
                            <views:RoutingView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:TunSettingsViewModel}">
                            <views:TunSettingsView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:LogsViewModel}">
                            <views:LogsView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                            <views:SettingsView />
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </Border>
        </Grid>
    </DockPanel>

    <!-- ═══════════════════════════════════════════════════════════════════
         Styles
         ═══════════════════════════════════════════════════════════════════ -->
    <Window.Styles>
        <!-- Sidebar nav button -->
        <Style Selector="Button.nav-button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.nav-button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BgHoverBrush}" />
        </Style>
        <Style Selector="Button.nav-button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BgCardBrush}" />
        </Style>

        <!-- Title bar window buttons -->
        <Style Selector="Button.titlebar-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.titlebar-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BgHoverBrush}" />
        </Style>
        <Style Selector="Button.close-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource RedBrush}" />
        </Style>
    </Window.Styles>

</Window>
