<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:SingBoxClient.Desktop.ViewModels"
        xmlns:local="using:SingBoxClient.Desktop"
        xmlns:views="using:SingBoxClient.Desktop.Views"
        x:Class="SingBoxClient.Desktop.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        mc:Ignorable="d"
        d:DesignWidth="960" d:DesignHeight="640"
        Title="NanoredVPN v1.0.0"
        Width="960" Height="640"
        MinWidth="800" MinHeight="550"
        Background="{StaticResource BgMainBrush}"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="40">

    <!-- ═══════════════════════════════════════════════════════════════════
         Main Layout: Title Bar + (Sidebar | Content)
         ═══════════════════════════════════════════════════════════════════ -->
    <DockPanel LastChildFill="True">

        <!-- ── Title Bar ────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource BgSidebarBrush}"
                Height="40"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="12,0">
                <!-- App title -->
                <TextBlock DockPanel.Dock="Left"
                           Text="NanoredVPN v1.0.0"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />

                <!-- Window control buttons -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center">
                    <!-- Theme toggle -->
                    <Button Background="{StaticResource BgInputBrush}"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10,5"
                            ToolTip.Tip="{Binding [ToggleTheme], Source={x:Static local:LocalizationManager.Instance}}"
                            Command="{Binding ToggleThemeCommand}">
                        <Panel>
                            <TextBlock Text="&#x2600;"
                                       IsVisible="{Binding IsDarkTheme}"
                                       Foreground="{StaticResource YellowBrush}"
                                       FontSize="16"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="&#x263E;"
                                       IsVisible="{Binding !IsDarkTheme}"
                                       Foreground="{StaticResource AccentLightBrush}"
                                       FontSize="16"
                                       VerticalAlignment="Center" />
                        </Panel>
                    </Button>

                    <!-- Minimize -->
                    <Button Classes="titlebar-btn"
                            ToolTip.Tip="{Binding [Minimize], Source={x:Static local:LocalizationManager.Instance}}"
                            Command="{Binding MinimizeCommand}">
                        <TextBlock Text="&#x2500;"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="13" />
                    </Button>

                    <!-- Maximize -->
                    <Button Classes="titlebar-btn"
                            ToolTip.Tip="{Binding [Maximize], Source={x:Static local:LocalizationManager.Instance}}"
                            Command="{Binding MaximizeCommand}">
                        <TextBlock Text="&#x25A1;"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="13" />
                    </Button>

                    <!-- Close -->
                    <Button Classes="titlebar-btn close-btn"
                            ToolTip.Tip="{Binding [Close], Source={x:Static local:LocalizationManager.Instance}}"
                            Command="{Binding CloseCommand}">
                        <TextBlock Text="&#x2715;"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="13" />
                    </Button>
                </StackPanel>

                <!-- Spacer -->
                <Panel />
            </DockPanel>
        </Border>

        <!-- ── Body: Sidebar + Content ──────────────────────────────── -->
        <Grid ColumnDefinitions="64,*">

            <!-- ── Sidebar ──────────────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{StaticResource BgSidebarBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <StackPanel VerticalAlignment="Top"
                            Spacing="4"
                            Margin="0,12">

                    <!-- Home -->
                    <Button Classes="nav-button"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Home"
                            ToolTip.Tip="{Binding [Home], Source={x:Static local:LocalizationManager.Instance}}"
                            IsEnabled="{Binding IsNotNavigating}">
                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                            <TextBlock Text="&#x2302;"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding [Home], Source={x:Static local:LocalizationManager.Instance}}"
                                       FontSize="9"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>
                    </Button>

                    <!-- Route -->
                    <Button Classes="nav-button"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Routing"
                            ToolTip.Tip="{Binding [Routing], Source={x:Static local:LocalizationManager.Instance}}"
                            IsEnabled="{Binding IsNotNavigating}">
                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                            <TextBlock Text="&#x21C4;"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding [Route], Source={x:Static local:LocalizationManager.Instance}}"
                                       FontSize="9"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>
                    </Button>

                    <!-- TUN -->
                    <Button Classes="nav-button"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="TunSettings"
                            ToolTip.Tip="{Binding [TunSettings], Source={x:Static local:LocalizationManager.Instance}}"
                            IsEnabled="{Binding IsNotNavigating}">
                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                            <TextBlock Text="&#x26A1;"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding [TUN], Source={x:Static local:LocalizationManager.Instance}}"
                                       FontSize="9"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>
                    </Button>

                    <!-- Logs -->
                    <Button Classes="nav-button"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Logs"
                            ToolTip.Tip="{Binding [Logs], Source={x:Static local:LocalizationManager.Instance}}"
                            IsEnabled="{Binding IsNotNavigating}">
                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                            <TextBlock Text="&#x2263;"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding [Logs], Source={x:Static local:LocalizationManager.Instance}}"
                                       FontSize="9"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>
                    </Button>

                    <!-- Settings -->
                    <Button Classes="nav-button"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Settings"
                            ToolTip.Tip="{Binding [Settings], Source={x:Static local:LocalizationManager.Instance}}"
                            IsEnabled="{Binding IsNotNavigating}">
                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                            <TextBlock Text="&#x2699;"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding [Setup], Source={x:Static local:LocalizationManager.Instance}}"
                                       FontSize="9"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ── Content Area ─────────────────────────────────────── -->
            <Border Grid.Column="1"
                    Background="{StaticResource BgContentBrush}">
                <ContentControl Content="{Binding CurrentPage}">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
                            <views:HomeView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:RoutingViewModel}">
                            <views:RoutingView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:TunSettingsViewModel}">
                            <views:TunSettingsView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:LogsViewModel}">
                            <views:LogsView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                            <views:SettingsView />
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </Border>
        </Grid>
    </DockPanel>

    <!-- ═══════════════════════════════════════════════════════════════════
         Styles
         ═══════════════════════════════════════════════════════════════════ -->
    <Window.Styles>
        <!-- Sidebar nav button -->
        <Style Selector="Button.nav-button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.nav-button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BgHoverBrush}" />
        </Style>
        <Style Selector="Button.nav-button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BgCardBrush}" />
        </Style>

        <!-- Title bar window buttons -->
        <Style Selector="Button.titlebar-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.titlebar-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BgHoverBrush}" />
        </Style>
        <Style Selector="Button.close-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource RedBrush}" />
        </Style>
    </Window.Styles>

</Window>
