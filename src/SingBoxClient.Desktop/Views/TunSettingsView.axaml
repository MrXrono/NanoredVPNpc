<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SingBoxClient.Desktop.ViewModels"
             x:Class="SingBoxClient.Desktop.Views.TunSettingsView"
             x:DataType="vm:TunSettingsViewModel"
             mc:Ignorable="d"
             d:DesignWidth="880" d:DesignHeight="640">

    <DockPanel Margin="24,20" LastChildFill="True">

        <!-- ═══════════════════════════════════════════════════════
             Header
             ═══════════════════════════════════════════════════════ -->
        <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,16">
            <TextBlock Text="{DynamicResource TunPerAppRules}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="18"
                       FontWeight="SemiBold" />
            <TextBlock Text="{DynamicResource TunDescription}"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="12"
                       TextWrapping="Wrap" />
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════
             Bottom: Note + Buttons
             ═══════════════════════════════════════════════════════ -->
        <StackPanel DockPanel.Dock="Bottom" Spacing="12" Margin="0,16,0,0">
            <!-- Note -->
            <Border Background="{DynamicResource BgInputBrush}"
                    CornerRadius="8"
                    Padding="12,8">
                <TextBlock Text="{DynamicResource TunNote}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="11"
                           TextWrapping="Wrap" />
            </Border>

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="10">
                <Button Content="{DynamicResource Cancel}"
                        Background="{DynamicResource BgInputBrush}"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        CornerRadius="8"
                        Padding="20,8"
                        FontSize="13"
                        Command="{Binding CancelCommand}" />
                <Button Content="{DynamicResource Save}"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        CornerRadius="8"
                        Padding="20,8"
                        FontSize="13"
                        Command="{Binding SaveCommand}" />
            </StackPanel>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════
             Three-Column Per-App Rules
             ═══════════════════════════════════════════════════════ -->
        <Grid ColumnDefinitions="*,12,*,12,*">

            <!-- ── Column 1: Bypass Proxy ───────────────────────── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BgCardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14">
                <DockPanel LastChildFill="True">
                    <!-- Header -->
                    <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,10">
                        <Border Background="{DynamicResource GreenBrush}"
                                CornerRadius="4"
                                Padding="8,4"
                                HorizontalAlignment="Left">
                            <TextBlock Text="{DynamicResource BypassProxy}"
                                       Foreground="White"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                        <TextBlock Text="{DynamicResource BypassDescription}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- TextBox -->
                    <TextBox Text="{Binding BypassApps}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Watermark="chrome.exe&#x0a;discord.exe&#x0a;..."
                             Background="{DynamicResource BgInputBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             CornerRadius="8"
                             Padding="10,8"
                             FontSize="12"
                             FontFamily="Consolas, monospace"
                             MinHeight="200" />
                </DockPanel>
            </Border>

            <!-- ── Column 2: Route via Proxy ────────────────────── -->
            <Border Grid.Column="2"
                    Background="{DynamicResource BgCardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14">
                <DockPanel LastChildFill="True">
                    <!-- Header -->
                    <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,10">
                        <Border Background="{DynamicResource AccentBrush}"
                                CornerRadius="4"
                                Padding="8,4"
                                HorizontalAlignment="Left">
                            <TextBlock Text="{DynamicResource RouteViaProxy}"
                                       Foreground="White"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                        <TextBlock Text="{DynamicResource RouteViaDescription}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- TextBox -->
                    <TextBox Text="{Binding ProxyApps}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Watermark="telegram.exe&#x0a;browser.exe&#x0a;..."
                             Background="{DynamicResource BgInputBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             CornerRadius="8"
                             Padding="10,8"
                             FontSize="12"
                             FontFamily="Consolas, monospace"
                             MinHeight="200" />
                </DockPanel>
            </Border>

            <!-- ── Column 3: Block Traffic ──────────────────────── -->
            <Border Grid.Column="4"
                    Background="{DynamicResource BgCardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14">
                <DockPanel LastChildFill="True">
                    <!-- Header -->
                    <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,10">
                        <Border Background="{DynamicResource RedBrush}"
                                CornerRadius="4"
                                Padding="8,4"
                                HorizontalAlignment="Left">
                            <TextBlock Text="{DynamicResource BlockTraffic}"
                                       Foreground="White"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                        <TextBlock Text="{DynamicResource BlockDescription}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- TextBox -->
                    <TextBox Text="{Binding BlockApps}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Watermark="malware.exe&#x0a;tracker.exe&#x0a;..."
                             Background="{DynamicResource BgInputBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             CornerRadius="8"
                             Padding="10,8"
                             FontSize="12"
                             FontFamily="Consolas, monospace"
                             MinHeight="200" />
                </DockPanel>
            </Border>
        </Grid>

    </DockPanel>

</UserControl>
