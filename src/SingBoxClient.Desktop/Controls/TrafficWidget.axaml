<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SingBoxClient.Desktop.Controls.TrafficWidget">
    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="16">
        <!-- Upload -->
        <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="&#x2191;" FontSize="12" Foreground="{DynamicResource GreenBrush}" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding UploadSpeed}" FontSize="12" Foreground="{DynamicResource GreenBrush}" VerticalAlignment="Center"/>
        </StackPanel>
        <!-- Download -->
        <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="&#x2193;" FontSize="12" Foreground="{DynamicResource AccentLightBrush}" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding DownloadSpeed}" FontSize="12" Foreground="{DynamicResource AccentLightBrush}" VerticalAlignment="Center"/>
        </StackPanel>
    </StackPanel>
</UserControl>
